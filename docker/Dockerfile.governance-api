COPY data-governance-engine/data-governance-engine-api/src data-governance-engine/data-governance-engine-api/src/

# Package applications
RUN mvn package -pl data-governance-engine/data-governance-engine-api -am -DskipTests

# Run Stage
FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /app/data-governance-engine/data-governance-engine-api/target/data-governance-engine-api-1.0.0-SNAPSHOT.jar app.jar
EXPOSE 8088
ENTRYPOINT ["java", "-jar", "app.jar"]
