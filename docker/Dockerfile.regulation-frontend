# Build Stage
FROM node:20-alpine AS build
WORKDIR /app
COPY research-dashboard-frontend/package.json research-dashboard-frontend/package-lock.json* ./
RUN npm install
COPY research-dashboard-frontend/ .
RUN npm run build

# Serve Stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
# Custom Nginx configuration to support client-side React Router
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
